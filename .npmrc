# npm publish auth for the official registry.
# NPM_TOKEN is read from the environment:
#   - locally:  set NPM_TOKEN in your shell (use an npm "Automation" access token)
#   - CI:       provided via the NPM_TOKEN repository secret (GitHub Actions)
# Never commit a real token here — only the ${NPM_TOKEN} reference.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
